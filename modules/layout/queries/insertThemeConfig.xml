<query id="insertThemeConfig" action="insert">
	<tables>
		<table name="theme_config" />
	</tables>
	<columns>
		<column name="theme_name" var="theme_name" notnull="notnull" />
		<column name="sub_name" var="sub_name" notnull="notnull" />
		<column name="config" var="config" notnull="notnull" />
		<column name="regdate" var="regdate" default="datetime()" />
	</columns>
</query>
