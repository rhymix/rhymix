<query id="deleteThemeConfig" action="delete">
	<tables>
		<table name="theme_config" />
	</tables>
	<conditions>
		<group notnull="notnull">
			<condition operation="equal" column="theme_srl" var="theme_srl" />
			<condition operation="equal" column="theme_name" var="theme_name" />
		</group>
	</conditions>
</query>
