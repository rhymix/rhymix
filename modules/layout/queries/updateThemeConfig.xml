<query id="updateThemeConfig" action="update">
	<tables>
		<table name="theme_config" />
	</tables>
	<columns>
		<column name="config" var="config" notnull="notnull" />
	</columns>
	<conditions>
		<condition operation="equal" column="theme_name" var="theme_name" notnull="notnull" />
		<condition operation="equal" column="sub_name" var="sub_name" notnull="notnull" />
	</conditions>
</query>
