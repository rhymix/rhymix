<query id="updatePackage" action="update">
	<tables>
		<table name="autoinstall_packages" />
	</tables>
	<columns>
		<column name="type" var="type" />
		<column name="title" var="title" />
		<column name="description" var="description" />
		<column name="author" var="author" />
		<column name="license" var="license" />
		<column name="last_release_version" var="last_release_version" />
		<column name="install_path" var="install_path" />
		<column name="install_type" var="install_type" />
		<column name="created" var="created" />
		<column name="updated" var="updated" />
		<column name="featured_count" var="featured_count" />
		<column name="extra_vars" var="extra_vars" />
	</columns>
	<conditions>
		<condition operation="equal" column="package_srl" var="package_srl" />
	</conditions>
</query>
