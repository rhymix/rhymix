<query id="insertPackage" action="insert">
	<tables>
		<table name="autoinstall_packages" />
	</tables>
	<columns>
		<column name="package_srl" var="package_srl" filter="number" notnull="notnull" />
		<column name="type" var="type" notnull="notnull" />
		<column name="title" var="title" notnull="notnull" />
		<column name="description" var="description" notnull="notnull" />
		<column name="author" var="author" notnull="notnull" />
		<column name="license" var="license" notnull="notnull" />
		<column name="last_release_version" var="last_release_version" notnull="notnull" />
		<column name="install_path" var="install_path" notnull="notnull" />
		<column name="install_type" var="install_type" notnull="notnull" />
		<column name="created" var="created" notnull="notnull" />
		<column name="updated" var="updated" notnull="notnull" />
		<column name="featured_count" var="featured_count" default="0" />
		<column name="list_order" var="list_order" default="0" />
		<column name="extra_vars" var="extra_vars" notnull="notnull" />
	</columns>
</query>
