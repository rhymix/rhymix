<query id="isExistsModuleName" action="select">
    <tables>
        <table name="modules" />
    </tables>
    <columns>
        <column name="count(*)" alias="count" />
    </columns>
    <conditions>
		<group>
        	<condition operation="in" column="mid" var="mid" notnull="notnull" />
			<condition operation="like_prefix" column="mid" var="mid_prefix" pipe="or" />
        </group>
        <condition operation="equal" column="domain_srl" var="domain_srl" />
        <condition operation="notequal" column="module_srl" var="module_srl" />
    </conditions>
</query>
